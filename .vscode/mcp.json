{
  "servers": {
    "oraios/serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena@v0.1.4",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "${workspaceFolder}"
      ]
    },
    "any-script": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "any-script-mcp"
      ],
      "env": {
        "ANY_SCRIPT_MCP_CONFIG": "${workspaceFolder}/.vscode/any-script-mcp.yaml"
      }
    }
  },
  "inputs": []
}
